@page
@model LoginModel

@{
    ViewData["Title"] = "เข้าสู่ระบบ";
}

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #F9F9F9 0%, rgb(193, 229, 159) 100%);
        /*
        margin: -20px -15px;
        padding: 40px 15px;
        */
    }
    .login-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
        max-width: 1000px;
        width: 100%;
    }
    .login-side {
        height: 100%;
        background: linear-gradient(135deg, #3F52E3 0%, rgb(163, 215, 138) 100%);
        color: white;
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }
    .login-side h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 20px;
    }
    .login-side p {
        font-size: 1.1rem;
        opacity: 0.9;
        margin-bottom: 30px;
    }
    .login-form-side {
        padding: 60px 50px;
    }
    .form-control:focus {
        border-color: #3F52E3;
        box-shadow: 0 0 0 0.25rem rgba(63, 82, 227, 0.15);
    }
    .btn-login {
        background: linear-gradient(135deg, #3F52E3 0%, rgb(163, 215, 138) 100%);
        border: none;
        color: white;
        font-weight: 600;
        padding: 14px;
        border-radius: 10px;
        transition: all 0.3s;
    }
    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(63, 82, 227, 0.3);
        background: linear-gradient(135deg, #3F52E3 0%, rgb(143, 195, 118) 100%);
    }
    .btn-social {
        border: 2px solid #e0e0e0;
        background: white;
        color: #333;
        font-weight: 500;
        padding: 12px;
        border-radius: 10px;
        transition: all 0.3s;
        margin: 8px 0;
    }
    .btn-social:hover {
        border-color: #3F52E3;
        background: #f8f9ff;
        transform: translateY(-2px);
    }
    .btn-google {
        background: rgb(255, 147, 126);
        color: white;
        border: none;
    }
    .btn-google:hover {
        background: rgb(255, 127, 106);
        color: white;
    }
    .btn-facebook {
        background: #3F52E3;
        color: white;
        border: none;
    }
    .btn-facebook:hover {
        background: #2F42D3;
        color: white;
    }
    .link-pastel {
        color: #3F52E3;
        text-decoration: none;
        transition: all 0.3s;
    }
    .link-pastel:hover {
        color: rgb(163, 215, 138);
        text-decoration: underline;
    }
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 30px 0;
    }
    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #e0e0e0;
    }
    .divider span {
        padding: 0 15px;
        color: #999;
        font-size: 0.9rem;
    }
    .alert-pastel {
        background: rgb(255, 147, 126);
        color: white;
        border: none;
        border-radius: 10px;
    }
    @@media (max-width: 768px) {
        .login-side {
            display: none;
        }
        .login-form-side {
            padding: 40px 30px;
        }
    }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="row g-0">
            <div class="col-lg-5 d-none d-lg-block">
                <div class="login-side">
                    <div>
                        <i class="bi bi-shop-window" style="font-size: 4rem; margin-bottom: 30px;"></i>
                        <a href="~/" target="_blank" class="text-underline text-white text-decoration-none">
                            <h2>🛍️ 99Baht Shop</h2>
                        </a>
                        <p>ระบบขาย เช่า ผ่อน<br/>ชุดสวมใส่ร่างกาย</p>
                        <div style="margin-top: 30px;">
                            <i class="bi bi-check-circle me-2"></i> ปลอดภัย<br/>
                            <i class="bi bi-check-circle me-2"></i> สะดวก<br/>
                            <i class="bi bi-check-circle me-2"></i> รวดเร็ว
                        </div>
                        <a href="~/" target="_blank" class="btn btn-outline-light mt-4">
                            <i class="bi bi-box-arrow-up-right"></i> เยี่ยมชมร้านค้า
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="login-form-side">
                    <div class="text-center mb-4 d-lg-none">
                        <h3><i class="bi bi-shop-window"></i> 99Baht Shop</h3>
                    </div>
                    <h2 class="mb-1 text-center"><i class="bi bi-box-arrow-in-right text-primary"></i> เข้าสู่ระบบ</h2>
                    <p class="text-muted mb-4 text-center">ยินดีต้อนรับกลับมา กรุณากรอกข้อมูลของคุณ</p>

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-pastel mb-4" role="alert"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">
                                <i class="bi bi-envelope"></i> อีเมล
                            </label>
                            <input asp-for="Input.Email" class="form-control form-control-lg" autocomplete="username" aria-required="true" placeholder="your@email.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">
                                <i class="bi bi-lock"></i> รหัสผ่าน
                            </label>
                            <input asp-for="Input.Password" type="password" class="form-control form-control-lg" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                        
                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label" asp-for="Input.RememberMe">
                                จดจำฉันไว้
                            </label>
                        </div>
                        
                        <div class="d-grid mb-3">
                            <button id="login-submit" type="submit" class="btn btn-lg btn-login">
                                <i class="bi bi-box-arrow-in-right"></i> เข้าสู่ระบบ
                            </button>
                        </div>
                    </form>
                        <div class="text-center">
                            <a id="forgot-password" asp-page="./ForgotPassword" class="link-pastel small">
                                <i class="bi bi-question-circle"></i> ลืมรหัสผ่าน?
                            </a>
                        </div>

                        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                        {
                            <div class="divider">
                                <span>หรือเข้าสู่ระบบด้วย</span>
                            </div>

                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                <div class="d-grid gap-2">
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        @if (provider.Name == "Google")
                                        {
                                            <button type="submit" class="btn btn-google btn-social" name="provider" value="@provider.Name" title="เข้าสู่ระบบด้วย @provider.DisplayName">
                                                <i class="bi bi-google"></i> เข้าสู่ระบบด้วย Google
                                            </button>
                                        }
                                        else if (provider.Name == "Facebook")
                                        {
                                            <button type="submit" class="btn btn-facebook btn-social" name="provider" value="@provider.Name" title="เข้าสู่ระบบด้วย @provider.DisplayName">
                                                <i class="bi bi-facebook"></i> เข้าสู่ระบบด้วย Facebook
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-social" name="provider" value="@provider.Name" title="เข้าสู่ระบบด้วย @provider.DisplayName">
                                                <i class="bi bi-box-arrow-in-right"></i> เข้าสู่ระบบด้วย @provider.DisplayName
                                            </button>
                                        }
                                    }
                                </div>
                            </form>
                        }

                        <hr class="my-4" />

                        <div class="text-center">
                            <p class="mb-2">
                                <small class="text-muted">ยังไม่มีบัญชี?</small>
                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link-pastel fw-bold">
                                    สมัครสมาชิก
                                </a>
                            </p>
                            <p class="mb-0">
                                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="link-pastel small">
                                    <i class="bi bi-envelope-check"></i> ส่งอีเมลยืนยันอีกครั้ง
                                </a>
                            </p>
                        </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
