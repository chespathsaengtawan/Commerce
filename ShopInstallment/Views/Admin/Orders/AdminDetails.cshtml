@model Order
@{
    ViewData["Title"] = $"รายละเอียดคำสั่งซื้อ #{Model.OrderNumber} - Admin";
    var statusBadge = Model.Status switch
    {
        "Pending" => "badge bg-warning text-dark",
        "Confirmed" => "badge bg-info text-white",
        "Completed" => "badge bg-success",
        "Cancelled" => "badge bg-danger",
        _ => "badge bg-secondary"
    };
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-receipt"></i> คำสั่งซื้อ #@Model.OrderNumber
            </h2>
            <p class="text-muted mb-0">รายละเอียดคำสั่งซื้อสำหรับ Admin</p>
        </div>
        <div>
            <a asp-action="AdminIndex" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> กลับ
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Order Information -->
        <div class="col-md-8">
            <!-- Order Details Card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle"></i> ข้อมูลคำสั่งซื้อ
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="text-muted mb-1">เลขที่คำสั่งซื้อ</p>
                            <p class="fw-bold">#@Model.OrderNumber</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1">สถานะ</p>
                            <p><span class="@statusBadge fs-6">@Model.Status</span></p>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="text-muted mb-1">ประเภท</p>
                            <p class="fw-bold">@Model.OrderType</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1">วันที่สร้าง</p>
                            <p class="fw-bold">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                    {
                        <div class="row">
                            <div class="col-12">
                                <p class="text-muted mb-1">ที่อยู่จัดส่ง</p>
                                <p class="fw-bold">@Model.ShippingAddress</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Customer Information -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">
                        <i class="bi bi-person-circle"></i> ข้อมูลผู้ซื้อ
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Customer != null)
                    {
                        <div class="row">
                            <div class="col-md-6">
                                <p class="text-muted mb-1">ชื่อ</p>
                                <p class="fw-bold">@Model.Customer.FirstName @Model.Customer.LastName</p>
                            </div>
                            <div class="col-md-6">
                                <p class="text-muted mb-1">อีเมล</p>
                                <p class="fw-bold">@Model.Customer.Email</p>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Customer.PhoneNumber))
                            {
                                <div class="col-md-6">
                                    <p class="text-muted mb-1">เบอร์โทร</p>
                                    <p class="fw-bold">@Model.Customer.PhoneNumber</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">ไม่มีข้อมูลผู้ซื้อ</p>
                    }
                </div>
            </div>

            <!-- Order Items -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">
                        <i class="bi bi-box-seam"></i> รายการสินค้า
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">สินค้า</th>
                                    <th>ผู้ขาย</th>
                                    <th class="text-center">จำนวน</th>
                                    <th class="text-end">ราคา/หน่วย</th>
                                    <th class="text-end pe-4">รวม</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    var seller = item.Product?.Seller;
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.Product?.MainImage))
                                                {
                                                    <img src="@item.Product.MainImage" alt="@item.Product.Name" 
                                                         class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                }
                                                <div>
                                                    <div class="fw-bold">@item.Product?.Name</div>
                                                    <small class="text-muted">ID: @item.ProductId</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (seller != null)
                                            {
                                                <div>
                                                    <i class="bi bi-shop text-info"></i>
                                                    <strong>@seller.FirstName</strong>
                                                </div>
                                                <small class="text-muted">@seller.Email</small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">ไม่มีข้อมูล</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@item.Quantity</span>
                                        </td>
                                        <td class="text-end">
                                            ฿@item.UnitPrice.ToString("N2")
                                        </td>
                                        <td class="text-end pe-4">
                                            <strong>฿@item.TotalPrice.ToString("N2")</strong>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Payments -->
            @if (Model.Payments.Any())
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0">
                            <i class="bi bi-credit-card"></i> การชำระเงิน
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Transaction ID</th>
                                        <th>วิธีการ</th>
                                        <th class="text-end">จำนวน</th>
                                        <th class="text-center">สถานะ</th>
                                        <th class="text-end pe-4">วันที่</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payment in Model.Payments.OrderByDescending(p => p.PaymentDate))
                                    {
                                        var paymentStatusBadge = payment.Status switch
                                        {
                                            "Completed" => "badge bg-success",
                                            "EscrowHold" => "badge bg-warning text-dark",
                                            "EscrowReleased" => "badge bg-info",
                                            "EscrowFrozen" => "badge bg-danger",
                                            _ => "badge bg-secondary"
                                        };

                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold">@payment.TransactionId</div>
                                                <small class="text-muted">ID: @payment.Id</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">@payment.PaymentMethod</span>
                                            </td>
                                            <td class="text-end">
                                                <strong>฿@payment.Amount.ToString("N2")</strong>
                                                @if (payment.FeeAmount > 0)
                                                {
                                                    <div><small class="text-muted">ค่าธรรมเนียม: ฿@payment.FeeAmount.ToString("N2")</small></div>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="@paymentStatusBadge">@payment.Status</span>
                                            </td>
                                            <td class="text-end pe-4">
                                                @payment.PaymentDate.ToString("dd/MM/yyyy HH:mm")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Summary Sidebar -->
        <div class="col-md-4">
            <!-- Financial Summary -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">
                        <i class="bi bi-wallet2"></i> สรุปการเงิน
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">มูลค่ารวม</span>
                        <span class="fw-bold">฿@Model.TotalAmount.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">ชำระแล้ว</span>
                        <span class="fw-bold text-success">฿@Model.PaidAmount.ToString("N2")</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold">คงเหลือ</span>
                        <span class="fw-bold @(Model.RemainingAmount > 0 ? "text-danger" : "text-success")">
                            ฿@Model.RemainingAmount.ToString("N2")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Admin Actions -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">
                        <i class="bi bi-tools"></i> จัดการคำสั่งซื้อ
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Status == "Pending")
                    {
                        <form asp-action="AdminConfirmOrder" method="post" class="mb-2">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success w-100" 
                                    onclick="return confirm('ยืนยันการดำเนินการคำสั่งซื้อนี้?')">
                                <i class="bi bi-check-circle"></i> ยืนยันคำสั่งซื้อ
                            </button>
                        </form>
                    }

                    @if (Model.Status != "Cancelled" && Model.Status != "Completed")
                    {
                        <form asp-action="AdminCancelOrder" method="post" class="mb-2">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger w-100" 
                                    onclick="return confirm('ยืนยันการยกเลิกคำสั่งซื้อนี้?')">
                                <i class="bi bi-x-circle"></i> ยกเลิกคำสั่งซื้อ
                            </button>
                        </form>
                    }

                    @if (Model.Status == "Confirmed" && Model.RemainingAmount == 0)
                    {
                        <form asp-action="AdminCompleteOrder" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-info w-100" 
                                    onclick="return confirm('ยืนยันการทำให้คำสั่งซื้อสำเร็จ?')">
                                <i class="bi bi-check2-all"></i> ทำให้สำเร็จ
                            </button>
                        </form>
                    }

                    <hr>

                    <a asp-controller="Payments" asp-action="Index" class="btn btn-outline-primary w-100 mb-2">
                        <i class="bi bi-credit-card"></i> ดูการชำระเงิน
                    </a>

                    <a asp-action="AdminIndex" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left"></i> กลับรายการทั้งหมด
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
