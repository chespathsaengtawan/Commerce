@model ShopInstallment.Models.Order
@{
    var setting = (ShopInstallment.Models.SellerPaymentSetting)ViewBag.SellerSetting;
    var coinBalance = (decimal)ViewBag.CoinBalance;
    ViewData["Title"] = $"รายละเอียดคำสั่งซื้อ: {Model.OrderNumber}";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<h2>รายละเอียดคำสั่งซื้อ</h2>
<div class="card mb-3">
    <div class="card-body">
        <div>เลขที่: <strong>@Model.OrderNumber</strong></div>
        <div>ยอดรวม: <strong>@Model.TotalAmount.ToString("N2")</strong> บาท</div>
        <div>ชำระแล้ว: <strong>@Model.PaidAmount.ToString("N2")</strong> บาท</div>
        <div>คงเหลือ: <span class="badge bg-warning text-dark">@Model.RemainingAmount.ToString("N2")</span> บาท</div>
        <div>ประเภท: @Model.OrderType</div>
        <div>สถานะ: @Model.Status</div>
    </div>
</div>

<h4>สินค้า</h4>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>สินค้า</th>
            <th>จำนวน</th>
            <th>ราคา/หน่วย</th>
            <th>รวม</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var i in Model.OrderItems)
    {
        <tr>
            <td>@i.Product?.Name</td>
            <td>@i.Quantity</td>
            <td>@i.UnitPrice.ToString("N2")</td>
            <td>@i.TotalPrice.ToString("N2")</td>
        </tr>
    }
    </tbody>
</table>

<h4>ช่องทางชำระเงิน</h4>

@if (Model.RemainingAmount > 0)
{
    <div class="alert alert-info mb-3">
        <i class="bi bi-wallet2"></i>
        <strong>ยอด Coin ของคุณ:</strong> @coinBalance.ToString("N2") Coin
        @if (coinBalance < Model.RemainingAmount)
        {
            <span class="text-danger">
                (ไม่เพียงพอ ต้องการ @Model.RemainingAmount.ToString("N2") Coin)
            </span>
            <a asp-controller="Wallet" asp-action="TopUp" class="btn btn-sm btn-primary ms-2">
                <i class="bi bi-plus-circle"></i> เติมเงิน
            </a>
        }
        else
        {
            <span class="text-success">
                <i class="bi bi-check-circle"></i> เพียงพอสำหรับชำระด้วย Coin
            </span>
        }
    </div>
}

@if (Model.RemainingAmount > 0)
{
    <div class="mt-4">
        <a asp-controller="Payments" asp-action="Create" asp-route-orderId="@Model.Id" 
           class="btn btn-success btn-lg">
            <i class="bi bi-credit-card"></i> ไปยังหน้าชำระเงิน
        </a>
    </div>
}

@if (Model.Payments?.Any() == true)
{
    <h4 class="mt-4">ประวัติการชำระเงิน</h4>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>เวลา</th>
                <th>วิธี</th>
                <th>ยอด</th>
                <th>ค่าธรรมเนียม</th>
                <th>สถานะ</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.Payments)
        {
            <tr>
                <td>@p.PaymentDate.ToLocalTime()</td>
                <td>@p.PaymentMethod</td>
                <td>@p.Amount.ToString("N2")</td>
                <td>@p.FeeAmount.ToString("N2")</td>
                <td>@p.Status</td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-controller="Payments" asp-action="ReleaseEscrow" method="post" class="d-inline">
                            <input type="hidden" name="paymentId" value="@p.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-success">ปล่อยเงิน</button>
                        </form>
                        <form asp-controller="Payments" asp-action="FreezeEscrow" method="post" class="d-inline ms-2">
                            <input type="hidden" name="paymentId" value="@p.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">ระงับเงิน</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
