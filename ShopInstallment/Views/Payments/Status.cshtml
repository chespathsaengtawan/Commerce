@model ShopInstallment.Models.Payment
@{
    ViewData["Title"] = "สถานะการชำระเงิน";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @if (Model.Status == "Completed")
            {
                <div class="card border-success">
                    <div class="card-body text-center py-5">
                        <div class="mb-4">
                            <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
                        </div>
                        <h4 class="text-success mb-3">ชำระเงินสำเร็จ</h4>
                        <p class="text-muted mb-4">ขอบคุณที่ใช้บริการของเรา</p>

                        <div class="alert alert-light border">
                            <p class="mb-1 text-muted">เลขที่ธุรกรรม</p>
                            <h6 class="font-monospace">@Model.TransactionId</h6>

                            <hr />

                            <p class="mb-1 text-muted">ยอดเงิน</p>
                            <h5>@Model.Amount.ToString("N2") ฿</h5>

                            <hr />

                            <p class="mb-1 text-muted">วิธีการชำระ</p>
                            <p class="mb-0"><strong>@Model.PaymentMethod</strong></p>
                        </div>

                        <div class="mt-4">
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId"
                               class="btn btn-success">
                                <i class="bi bi-arrow-right"></i> ดูรายละเอียดคำสั่ง
                            </a>
                        </div>
                    </div>
                </div>
            }
            else if (Model.Status == "EscrowHold")
            {
                <div class="card border-warning">
                    <div class="card-body text-center py-5">
                        <div class="mb-4">
                            <i class="bi bi-hourglass-split text-warning" style="font-size: 4rem;"></i>
                        </div>
                        <h4 class="text-warning mb-3">รอการตรวจสอบ</h4>
                        <p class="text-muted mb-4">เงินของคุณอยู่ในระหว่างการตรวจสอบ</p>

                        <div class="alert alert-light border">
                            <p class="mb-1 text-muted">เลขที่ธุรกรรม</p>
                            <h6 class="font-monospace">@Model.TransactionId</h6>

                            <hr />

                            <p class="mb-1 text-muted">ยอดเงิน</p>
                            <h5>@Model.Amount.ToString("N2") ฿</h5>

                            <hr />

                            <p class="mb-1 text-muted">สถานะ</p>
                            <span class="badge bg-warning p-2">รอการปล่อยเงิน (Escrow Hold)</span>
                        </div>

                        <div class="alert alert-info mt-4">
                            <i class="bi bi-info-circle"></i>
                            <small>เงินของคุณจะถูกปล่อยออกมาเมื่อสินค้าผ่านการตรวจสอบ</small>
                        </div>

                        <div class="mt-4">
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId"
                               class="btn btn-warning">
                                <i class="bi bi-arrow-right"></i> ดูรายละเอียด
                            </a>
                        </div>
                    </div>
                </div>
            }
            else if (Model.Status == "EscrowReleased")
            {
                <div class="card border-info">
                    <div class="card-body text-center py-5">
                        <div class="mb-4">
                            <i class="bi bi-unlock text-info" style="font-size: 4rem;"></i>
                        </div>
                        <h4 class="text-info mb-3">ปล่อยเงินแล้ว</h4>
                        <p class="text-muted mb-4">เงินของคุณได้ถูกปล่อยแล้ว</p>

                        <div class="alert alert-light border">
                            <p class="mb-1 text-muted">เลขที่ธุรกรรม</p>
                            <h6 class="font-monospace">@Model.TransactionId</h6>

                            <hr />

                            <p class="mb-1 text-muted">ยอดเงิน</p>
                            <h5>@Model.Amount.ToString("N2") ฿</h5>
                        </div>

                        <div class="mt-4">
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId"
                               class="btn btn-info">
                                <i class="bi bi-arrow-right"></i> ดูรายละเอียด
                            </a>
                        </div>
                    </div>
                </div>
            }
            else if (Model.Status == "EscrowFrozen")
            {
                <div class="card border-danger">
                    <div class="card-body text-center py-5">
                        <div class="mb-4">
                            <i class="bi bi-lock text-danger" style="font-size: 4rem;"></i>
                        </div>
                        <h4 class="text-danger mb-3">เงินถูกระงับ</h4>
                        <p class="text-muted mb-4">การชำระเงินของคุณได้ถูกระงับโดยแอดมิน</p>

                        <div class="alert alert-light border">
                            <p class="mb-1 text-muted">เลขที่ธุรกรรม</p>
                            <h6 class="font-monospace">@Model.TransactionId</h6>

                            <hr />

                            <p class="mb-1 text-muted">ยอดเงิน</p>
                            <h5>@Model.Amount.ToString("N2") ฿</h5>

                            <hr />

                            <p class="mb-1 text-muted">เหตุผล</p>
                            <p class="mb-0 text-muted">@(Model.Notes ?? "ไม่มีหมายเหตุ")</p>
                        </div>

                        <div class="alert alert-warning mt-4">
                            <i class="bi bi-exclamation-triangle"></i>
                            <small>โปรดติดต่อเจ้าของร้านเพื่อรับการสนับสนุน</small>
                        </div>

                        <div class="mt-4">
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId"
                               class="btn btn-danger">
                                <i class="bi bi-arrow-right"></i> ดูรายละเอียด
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <div class="mb-4">
                            <i class="bi bi-question-circle text-secondary" style="font-size: 4rem;"></i>
                        </div>
                        <h4 class="text-secondary mb-3">สถานะไม่ทราบ</h4>
                        <p class="text-muted mb-4">ไม่สามารถระบุสถานะการชำระเงิน</p>

                        <div class="alert alert-light border">
                            <p class="mb-1 text-muted">สถานะปัจจุบัน</p>
                            <h6>@Model.Status</h6>
                        </div>

                        <div class="mt-4">
                            <a asp-controller="Orders" asp-action="Index"
                               class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> กลับไปที่รายการคำสั่ง
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
