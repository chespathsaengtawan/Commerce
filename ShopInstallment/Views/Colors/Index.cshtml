@model IEnumerable<ShopInstallment.Models.Color>
@{
    ViewData["Title"] = "จัดการสี";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2> จัดการสี</h2>
    <a class="btn  btn-outline-primary" asp-action="Create">
        <i class="bi bi-plus-circle"></i> เพิ่มสี
    </a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ชื่อสี</th>
                    <th>รหัสสี</th>
                    <th style="width: 80px;">ตัวอย่าง</th>
                    <th>สถานะ</th>
                    <th style="width: 150px;">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Any() == true)
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                            </td>
                            <td>
                                <code>@item.HexCode</code>
                            </td>
                            <td>
                                <div style="width: 50px; height: 30px; background-color: @item.HexCode; border: 1px solid #ccc; border-radius: 4px;"></div>
                            </td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <span class="badge bg-success">ใช้งาน</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">ไม่ใช้งาน</span>
                                }
                            </td>
                            <td>
            
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> แก้ไข
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger delete-button">
                                         <i class="bi bi-trash"></i> ลบ
                                    </a>
                                
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-inbox"></i> ยังไม่มีสี
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
