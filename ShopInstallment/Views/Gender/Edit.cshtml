@model ShopInstallment.Models.Gender
@{
    ViewData["Title"] = "แก้ไขเพศสภาพ";
}
<h2>แก้ไขเพศสภาพ</h2>
<form asp-action="Edit" method="post" class="card p-3">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-success">บันทึก</button>
    <a asp-action="Index" class="btn btn-secondary">ย้อนกลับ</a>
</form>
