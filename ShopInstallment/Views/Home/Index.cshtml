@model List<ShopInstallment.Models.Product>
@{
    ViewData["Title"] = "🛍️ 99Baht Shop - เสื้อผ้า ชุดสวมใส่ ขาย เช่า ผ่อน";
    var categories = (List<ShopInstallment.Models.Category>)ViewBag.Categories;
}


<!-- Hero Banner Section -->
<div class="container-fluid px-0 mb-5">
    <div class="row g-0">
        <div class="col-12">
            <div class="hero-banner position-relative" style="background-image: url('/images/hero-banner.jpg'); background-size: cover; background-position: center; height: 400px;">
                <div class="overlay position-absolute top-0 start-0 end-0 bottom-0 bg-dark bg-opacity-50 d-flex flex-column justify-content-center align-items-center text-center text-white">
                    <h1 class="display-4 fw-bold mb-3" style="font-family: 'Brush Script MT', cursive;">
                        Welcome to 99Baht Shop
                    </h1>
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4">
        <!-- Main Hero -->
        <div class="col-md-6">
            <div class="hero-section p-5 d-flex h-100" style="min-height: 720px;">
                <div class="ms-auto my-auto col-md-6">
                    <h1 class="display-4 fw-bold mb-3" style="font-family: 'Brush Script MT', cursive; color: #333;">
                        Women's 
                    </h1>
                    <h2>Fashion</h2>
                    <p class="lead text-muted mb-4">
                        Stylish, comfortable collection curated for the modern woman.
                    </p>
                    <a href="@Url.Action("Index", "Products")" class="btn btn-dark btn-lg">
                        <i class="bi bi-shop"></i> SHOP NOW
                    </a>
                </div>
            </div>
        </div>

        <!-- Category Grid -->
        <div class="col-md-6">
            <div class="row h-100 g-4">
                <!-- Men's Fashion -->
                <div class="col-md-6">
                    <div class="mens-fashion category-card p-2 d-flex justify-content-center align-items-center position-relative" 
                         style="cursor: pointer; transition: transform 0.3s; "
                         onclick="location.href='@Url.Action("Index", "Products", new { categoryId = 1 })'">
                        <span class="category-badge category-badge-bg category-badge-white">
                           Men's fashion
                        </span>
                    </div>                 
                </div>

                <!-- Kids Fashion -->
                <div class="col-md-6">
                    <div class="kids-fashion category-card p-2 d-flex justify-content-center align-items-center position-relative" 
                         style="cursor: pointer; transition: transform 0.3s; "
                         onclick="location.href='@Url.Action("Index", "Products", new { categoryId = 2 })'">
                        <span class="category-badge category-badge-bg category-badge-white">
                            Kids' fashion
                        </span>
                    </div>
                </div>
            
                <!-- Cosmetics -->
                <div class="col-md-6">
                    <div class="cosmetics category-card p-2 d-flex justify-content-center align-items-center position-relative" 
                         style="cursor: pointer; transition: transform 0.3s; "
                         onclick="location.href='@Url.Action("Index", "Products", new { categoryId = 3 })'">
                        <span class="category-badge category-badge-bg category-badge-white">
                            Cosmetics
                        </span>
                    </div>
                </div>

                <!-- Accessories -->
                <div class="col-md-6">
                    <div class="accessories category-card p-2 d-flex justify-content-center align-items-center position-relative" 
                         style="cursor: pointer; transition: transform 0.3s; "
                         onclick="location.href='@Url.Action("Index", "Products", new { categoryId = 4 })'">
                        <span class="category-badge category-badge-bg category-badge-white">
                            Accessories
                        </span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- New Products Section -->
<div class="container-fluid mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">
            <i class="bi bi-star-fill" style="color: #FFB347;"></i> NEW PRODUCT
        </h4>
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-sm btn-outline-dark active">All</button>
            <button type="button" class="btn btn-sm btn-outline-dark">Women's</button>
            <button type="button" class="btn btn-sm btn-outline-dark">Men's</button>
            <button type="button" class="btn btn-sm btn-outline-dark">Kids</button>
            <button type="button" class="btn btn-sm btn-outline-dark">Accessories</button>
            <button type="button" class="btn btn-sm btn-outline-dark">Cosmetics</button>
        </div>
    </div>

    <div class="row g-4">
        @if (Model?.Any() == true)
        {
            @foreach (var product in Model)
            {
                var mainImage = product.Images?.FirstOrDefault(p => p.IsMain)?.ImageUrl 
                             ?? product.Images?.FirstOrDefault()?.ImageUrl 
                             ?? product.MainImage
                             ?? "/images/placeholder.png";
                var rating = product.Ratings?.Any() == true 
                           ? Math.Round(product.Ratings.Average(r => (double)r.Stars), 1) 
                           : 0d;
                var ratingCount = product.Ratings?.Count() ?? 0;

                <div class="col-md-6 col-lg-3">
                    <div class="product-card h-100">
                        <!-- Badge -->
                        @if (product.Stock < 5 && product.Stock > 0)
                        {
                            <div class="position-absolute top-0 start-0 m-2 z-2">
                                <span class="badge bg-danger">Limited</span>
                            </div>
                        }
                        @if (product.Stock == 0)
                        {
                            <div class="position-absolute top-0 start-0 m-2 z-2">
                                <span class="badge bg-secondary">Out of Stock</span>
                            </div>
                        }

                        <!-- Image -->
                        <div class="product-image-wrapper position-relative overflow-hidden bg-light mb-3" style="height: 280px;">
                            <img src="@mainImage" alt="@product.Name" class="img-fluid w-100 h-100 object-fit-cover">
                            <div class="position-absolute bottom-0 start-0 end-0 bg-dark bg-opacity-50 p-2 text-white" style="opacity: 0; transition: opacity 0.3s;">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-light w-100">
                                    <i class="bi bi-eye"></i> View Details
                                </a>
                            </div>
                        </div>

                        <!-- Product Info -->
                        <div class="product-info">
                            <h6 class="product-name mb-2" title="@product.Name">
                                @if (product.Name.Length > 30)
                                {
                                    @product.Name.Substring(0, 30)<span>...</span>
                                }
                                else
                                {
                                    @product.Name
                                }
                            </h6>

                            <!-- Rating -->
                            <div class="mb-2">
                                <div class="rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Floor(rating))
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else if (i - rating < 1)
                                        {
                                            <i class="bi bi-star-half text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-warning"></i>
                                        }
                                    }
                                </div>
                                <small class="text-muted">(@ratingCount reviews)</small>
                            </div>

                            <!-- Price -->
                            <div class="mb-3">
                                <h5 class="text-primary fw-bold">฿@product.PricePerUnit.ToString("N2")</h5>
                                @if (product.RentPricePerDay.HasValue)
                                {
                                    <small class="text-muted d-block">
                                        <i class="bi bi-calendar-event"></i> ฿@product.RentPricePerDay.Value.ToString("N2")/day
                                    </small>
                                }
                            </div>

                            <!-- Stock Status -->
                            <small class="text-muted d-block mb-2">
                                @if (product.Stock > 0)
                                {
                                    <span class="text-success">
                                        <i class="bi bi-check-circle"></i> In Stock (@product.Stock)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-danger">
                                        <i class="bi bi-x-circle"></i> Out of Stock
                                    </span>
                                }
                            </small>

                            <!-- Add to Cart Button -->
                            <div class="d-grid gap-2">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" 
                                   class="btn btn-primary btn-sm">
                                    <i class="bi bi-bag-plus"></i> View Product
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="bi bi-inbox"></i> ยังไม่มีสินค้า
                </div>
            </div>
        }
    </div>

    <!-- View All Button -->
    <div class="text-center mt-5">
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary btn-lg">
            <i class="bi bi-arrow-right-circle"></i> VIEW ALL PRODUCTS
        </a>
    </div>
</div>
