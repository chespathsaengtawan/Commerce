@model ShopInstallment.Models.SellerPaymentSetting
@{
    ViewData["Title"] = "การตั้งค่าการชำระเงิน";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<h2><i class="bi bi-gear-fill"></i> การตั้งค่าการชำระเงิน</h2>
<p class="text-muted">กำหนดวิธีการชำระเงินที่รับและค่าธรรมเนียมสำหรับร้านค้าของคุณ</p>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="card-title mb-0">ช่องทางการชำระเงินที่เปิดรับ</h5>
            <a asp-action="Edit" class="btn btn-primary btn-sm">
                <i class="bi bi-pencil"></i> แก้ไข
            </a>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card h-100 @(Model.AllowPromptPay ? "border-success" : "border-secondary")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title">
                                    <i class="bi bi-qr-code"></i> PromptPay
                                </h6>
                                <p class="mb-0">
                                    สถานะ: 
                                    @if (Model.AllowPromptPay)
                                    {
                                        <span class="badge bg-success">เปิดรับ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">ปิด</span>
                                    }
                                </p>
                                <p class="mb-0 text-muted">
                                    ค่าธรรมเนียม: <strong>@Model.PromptPayFeePercent%</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100 @(Model.AllowBillPayment ? "border-success" : "border-secondary")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title">
                                    <i class="bi bi-receipt"></i> Bill Payment
                                </h6>
                                <p class="mb-0">
                                    สถานะ: 
                                    @if (Model.AllowBillPayment)
                                    {
                                        <span class="badge bg-success">เปิดรับ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">ปิด</span>
                                    }
                                </p>
                                <p class="mb-0 text-muted">
                                    ค่าธรรมเนียม: <strong>@Model.BillPaymentFeePercent%</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100 @(Model.AllowTrueWallet ? "border-success" : "border-secondary")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title">
                                    <i class="bi bi-wallet2"></i> True Wallet
                                </h6>
                                <p class="mb-0">
                                    สถานะ: 
                                    @if (Model.AllowTrueWallet)
                                    {
                                        <span class="badge bg-success">เปิดรับ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">ปิด</span>
                                    }
                                </p>
                                <p class="mb-0 text-muted">
                                    ค่าธรรมเนียม: <strong>@Model.TrueWalletFeePercent%</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100 @(Model.AllowBankTransfer ? "border-success" : "border-secondary")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title">
                                    <i class="bi bi-bank"></i> โอนผ่านธนาคาร
                                </h6>
                                <p class="mb-0">
                                    สถานะ: 
                                    @if (Model.AllowBankTransfer)
                                    {
                                        <span class="badge bg-success">เปิดรับ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">ปิด</span>
                                    }
                                </p>
                                <p class="mb-0 text-muted">
                                    ค่าธรรมเนียม: <strong>@Model.BankTransferFeePercent%</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100 @(Model.AllowCoin ? "border-success" : "border-secondary")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title">
                                    <i class="bi bi-coin"></i> Coin ภายในระบบ
                                </h6>
                                <p class="mb-0">
                                    สถานะ: 
                                    @if (Model.AllowCoin)
                                    {
                                        <span class="badge bg-success">เปิดรับ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">ปิด</span>
                                    }
                                </p>
                                <p class="mb-0 text-muted">
                                    ค่าธรรมเนียม: <strong>@Model.CoinFeePercent%</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-info mt-4" role="alert">
            <i class="bi bi-info-circle"></i> 
            <strong>หมายเหตุ:</strong> ค่าธรรมเนียมจะถูกหักจากยอดเงินที่คุณได้รับ ตัวอย่างเช่น หากลูกค้าชำระ 1,000 บาทด้วย PromptPay (ค่าธรรมเนียม 1.5%) คุณจะได้รับ 985 บาท
        </div>
    </div>
</div>
