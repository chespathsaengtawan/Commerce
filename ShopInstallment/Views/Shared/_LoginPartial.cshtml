@using System.Security.Principal

<ul class="navbar-nav gap-2">
@if (User.Identity?.IsAuthenticated == true)
{
    @*<span class="navbar-text text-dark">Hello @User.Identity?.Name!</span>*@
    <li class="nav-item">
        <a class="btn btn-outline-light" asp-area="Identity" asp-page="/Account/Manage/Index">บัญชีของฉัน</a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
            <button type="submit" class="btn btn-outline-light">ออกจากระบบ</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-outline-light" asp-area="Identity" asp-page="/Account/Login">เข้าใช้งาน</a>
    </li>
}
</ul>
