@model ShopInstallment.Models.Category
@{
    ViewData["Title"] = "เพิ่มหมวดหมู่";
}
<h2>เพิ่มหมวดหมู่</h2>

@* แสดง Validation Summary *@
@*<div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>*@

@* แสดง TempData errors จาก Controller *@
@if (TempData["SuccessMessage"] != null)
{
    <script>
        Toast.fire({
            icon: 'success',
            title: '@TempData["SuccessMessage"]'
        });
    </script>
}

@if (TempData["ErrorMessage"] != null)
{
    <script>
        Toast.fire({
            icon: 'error',
            title: '@TempData["ErrorMessage"]'
        });
    </script>
}
<form asp-action="Create" method="post" class="card p-3">
    <div class="mb-3">
        <label asp-for="Name" class="form-label">ชื่อหมวดหมู่</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="GenderId" class="form-label">เพศสภาพ</label>
        <select asp-for="GenderId" class="form-select" asp-items="@(new SelectList((IEnumerable<ShopInstallment.Models.Gender>)ViewBag.Genders, nameof(ShopInstallment.Models.Gender.Id), nameof(ShopInstallment.Models.Gender.Name)))">
            <option value="">-- เลือกเพศสภาพ --</option>
        </select>
        <span asp-validation-for="GenderId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">คำอธิบาย</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label">สถานะ</label>
        <select asp-for="Status" class="form-select">
            <option>Active</option>
            <option>Inactive</option>
        </select>
    </div>
    <div class="d-flex flex-row gap-2 justify-content-end">
        <button type="submit" class="btn btn-outline-success"> <i class="bi bi-check-circle"></i> บันทึก</button>
        <a asp-action="Index" class="btn btn-outline-danger"> <i class="bi bi-arrow-left-circle"></i> ย้อนกลับ</a>
    </div>
</form>
