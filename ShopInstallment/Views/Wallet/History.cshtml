@model List<ShopInstallment.Models.CoinTransaction>
@{
    ViewData["Title"] = "ประวัติการใช้งาน Coin";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
}

<h2><i class="bi bi-clock-history"></i> ประวัติการใช้งาน Coin</h2>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> กลับหน้ากระเป๋าเงิน
                </a>
            </div>
            <div>
                <span class="badge bg-info">ทั้งหมด @Model.Count รายการในหน้านี้</span>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>วันที่/เวลา</th>
                            <th>ประเภท</th>
                            <th>รายละเอียด</th>
                            <th class="text-end">จำนวน</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td>
                                    <small>@t.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</small><br />
                                    <small class="text-muted">@t.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</small>
                                </td>
                                <td>
                                    @if (t.Type == "TopUp")
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-plus-circle"></i> เติมเงิน
                                        </span>
                                    }
                                    else if (t.Type == "Spend")
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-dash-circle"></i> ใช้จ่าย
                                        </span>
                                    }
                                    else if (t.Type == "Refund")
                                    {
                                        <span class="badge bg-info">
                                            <i class="bi bi-arrow-counterclockwise"></i> คืนเงิน
                                        </span>
                                    }
                                </td>
                                <td>
                                    @t.Reference
                                </td>
                                <td class="text-end">
                                    @if (t.Amount >= 0)
                                    {
                                        <span class="text-success fw-bold">
                                            +@t.Amount.ToString("N2") <i class="bi bi-coin"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">
                                            @t.Amount.ToString("N2") <i class="bi bi-coin"></i>
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="History" asp-route-page="@(currentPage - 1)">
                                <i class="bi bi-chevron-left"></i> ก่อนหน้า
                            </a>
                        </li>

                        @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="History" asp-route-page="@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="History" asp-route-page="@(currentPage + 1)">
                                ถัดไป <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="text-center text-muted p-5">
                <i class="bi bi-inbox display-1"></i>
                <p class="mt-3">ยังไม่มีประวัติการใช้งาน</p>
                <a asp-action="TopUp" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> เติมเงินเลย
                </a>
            </div>
        }
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="bi bi-plus-circle-fill text-success display-4"></i>
                <h6 class="mt-2">เติมเงิน</h6>
                <p class="small text-muted">เพิ่มยอด Coin เข้ากระเป๋า</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="bi bi-dash-circle-fill text-danger display-4"></i>
                <h6 class="mt-2">ใช้จ่าย</h6>
                <p class="small text-muted">หักยอดเมื่อซื้อสินค้า</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="bi bi-arrow-counterclockwise text-info display-4"></i>
                <h6 class="mt-2">คืนเงิน</h6>
                <p class="small text-muted">รับคืนเมื่อยกเลิก</p>
            </div>
        </div>
    </div>
</div>
