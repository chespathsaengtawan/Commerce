@using System.Security.Claims
@model IEnumerable<ShopInstallment.Models.Order>
@{
    ViewData["Title"] = "ศูนย์การเงินผู้ขาย";
    var wallet = (ShopInstallment.Models.CoinWallet)ViewBag.Wallet;
    var sellerSetting = (ShopInstallment.Models.SellerPaymentSetting)ViewBag.SellerSetting;
    var totalOrderAmount = (decimal)ViewBag.TotalOrderAmount;
    var totalPaidAmount = (decimal)ViewBag.TotalPaidAmount;
    var completedOrders = (int)ViewBag.CompletedOrders;
    var pendingOrders = (int)ViewBag.PendingOrders;
    var confirmedOrders = (int)ViewBag.ConfirmedOrders;
    var recentTransactions = (List<ShopInstallment.Models.CoinTransaction>)ViewBag.RecentTransactions;
    var totalOrders = (int)ViewBag.TotalOrders;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-cash-coin"></i> ศูนย์การเงินผู้ขาย</h2>
            <p class="text-muted mb-0">ข้อมูลการเงินและคำสั่งซื้อของคุณ</p>
        </div>
        <div>
            <a href="/Seller/Orders" class="btn btn-outline-secondary">
                <i class="bi bi-cart-check"></i> ดูคำสั่งซื้อทั้งหมด
            </a>
        </div>
    </div>

    <!-- Coin Wallet Summary -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body">
                    <p class="card-text text-white-50 mb-1">ยอด Coin คงเหลือ</p>
                    <h3 class="display-5 mb-2">฿@wallet.Balance.ToString("N2")</h3>
                    <small>อัพเดท: @wallet.UpdatedAt.ToLocalTime().ToString("dd/MM HH:mm")</small>
                    <div class="mt-3">
                        <a href="/Wallet/TopUp" class="btn btn-light btn-sm">
                            <i class="bi bi-plus-circle"></i> เติมเงิน
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white h-100">
                <div class="card-body">
                    <p class="card-text text-white-50 mb-1">ยอดขายรวม</p>
                    <h3 class="display-5 mb-2">฿@totalOrderAmount.ToString("N2")</h3>
                    <small>จากคำสั่งซื้อ @totalOrders รายการ</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-info text-white h-100">
                <div class="card-body">
                    <p class="card-text text-white-50 mb-1">ชำระแล้ว</p>
                    <h3 class="display-5 mb-2">฿@totalPaidAmount.ToString("N2")</h3>
                    <small>สำเร็จ @completedOrders คำสั่งซื้อ</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark h-100">
                <div class="card-body">
                    <p class="card-text text-dark-50 mb-1">รอตรวจสอบ</p>
                    <h3 class="display-5 mb-2">@pendingOrders</h3>
                    <small>Pending + Confirmed: @confirmedOrders</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Status Summary -->
    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0"><i class="bi bi-clipboard-data"></i> สรุปสถานะคำสั่งซื้อ</h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-3">
                            <div class="text-muted small">Pending</div>
                            <h4 class="text-warning mb-0">@pendingOrders</h4>
                        </div>
                        <div class="col-3">
                            <div class="text-muted small">Confirmed</div>
                            <h4 class="text-info mb-0">@confirmedOrders</h4>
                        </div>
                        <div class="col-3">
                            <div class="text-muted small">Completed</div>
                            <h4 class="text-success mb-0">@completedOrders</h4>
                        </div>
                        <div class="col-3">
                            <div class="text-muted small">ทั้งหมด</div>
                            <h4 class="mb-0">@totalOrders</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0"><i class="bi bi-gear"></i> ตั้งค่าการชำระเงิน</h6>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between px-0">
                            <small>PromptPay <span class="@(sellerSetting.AllowPromptPay ? "text-success" : "text-danger")">@(sellerSetting.AllowPromptPay ? "เปิด" : "ปิด")</span></small>
                            <strong>@sellerSetting.PromptPayFeePercent%</strong>
                        </div>
                        <div class="list-group-item d-flex justify-content-between px-0">
                            <small>Bill Payment <span class="@(sellerSetting.AllowBillPayment ? "text-success" : "text-danger")">@(sellerSetting.AllowBillPayment ? "เปิด" : "ปิด")</span></small>
                            <strong>@sellerSetting.BillPaymentFeePercent%</strong>
                        </div>
                        <div class="list-group-item d-flex justify-content-between px-0">
                            <small>True Wallet <span class="@(sellerSetting.AllowTrueWallet ? "text-success" : "text-danger")">@(sellerSetting.AllowTrueWallet ? "เปิด" : "ปิด")</span></small>
                            <strong>@sellerSetting.TrueWalletFeePercent%</strong>
                        </div>
                        <div class="list-group-item d-flex justify-content-between px-0">
                            <small>Bank Transfer <span class="@(sellerSetting.AllowBankTransfer ? "text-success" : "text-danger")">@(sellerSetting.AllowBankTransfer ? "เปิด" : "ปิด")</span></small>
                            <strong>@sellerSetting.BankTransferFeePercent%</strong>
                        </div>
                        <div class="list-group-item d-flex justify-content-between px-0">
                            <small>Coin <span class="@(sellerSetting.AllowCoin ? "text-success" : "text-danger")">@(sellerSetting.AllowCoin ? "เปิด" : "ปิด")</span></small>
                            <strong>@sellerSetting.CoinFeePercent%</strong>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="/SellerSettings" class="btn btn-sm btn-outline-primary w-100">
                            <i class="bi bi-pencil"></i> แก้ไขตั้งค่า
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0"><i class="bi bi-clock-history"></i> ธุรกรรม Coin ล่าสุด</h6>
                </div>
                <div class="card-body p-0">
                    @if (recentTransactions?.Any() == true)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <tbody>
                                    @foreach (var trans in recentTransactions.Take(5))
                                    {
                                        var typeLabel = trans.Type switch
                                        {
                                            "TopUp" => ("เติมเงิน", "success"),
                                            "Spend" => ("ใช้จ่าย", "danger"),
                                            "Refund" => ("คืนเงิน", "info"),
                                            _ => ("อื่น ๆ", "secondary")
                                        };
                                        <tr>
                                            <td>
                                                <span class="badge bg-@typeLabel.Item2">@typeLabel.Item1</span>
                                            </td>
                                            <td>
                                                <small class="text-muted">@trans.Reference</small>
                                            </td>
                                            <td class="text-end">
                                                <strong class="@(trans.Amount > 0 ? "text-success" : "text-danger")">
                                                    @(trans.Amount > 0 ? "+" : "")฿@trans.Amount.ToString("N2")
                                                </strong>
                                                <br />
                                                <small class="text-muted">@trans.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <small>ยังไม่มีธุรกรรม</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> ข้อมูลการชำระเงิน</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-0">
                        <small>
                            <i class="bi bi-info-circle"></i>
                            ตั้งค่าวิธีการชำระเงินและค่าธรรมเนียมของคุณได้ในหน้า "ตั้งค่าการชำระเงิน"
                        </small>
                    </div>
                    <div class="mt-3">
                        <a href="/SellerSettings" class="btn btn-sm btn-outline-primary w-100">
                            <i class="bi bi-pencil"></i> ไปยังหน้าตั้งค่า
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom">
            <h6 class="mb-0"><i class="bi bi-receipt"></i> คำสั่งซื้อล่าสุด</h6>
        </div>
        <div class="card-body p-0">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 12%;">เลขที่</th>
                                <th style="width: 15%;">ผู้ซื้อ</th>
                                <th style="width: 10%;">จำนวน<br/>สินค้า</th>
                                <th style="width: 12%;">ยอดรวม</th>
                                <th style="width: 12%;">ชำระแล้ว</th>
                                <th style="width: 12%;">สถานะ</th>
                                <th style="width: 15%;">วันเวลา</th>
                                <th style="width: 12%;">จัดการ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.OrderByDescending(o => o.CreatedAt).Take(10))
                            {
                                var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                                var sellerItemCount = order.OrderItems.Count(oi => oi.Product.SellerId == userId);

                                if (sellerItemCount == 0) continue;

                                var statusBadge = order.Status switch
                                {
                                    "Pending" => "badge bg-warning text-dark",
                                    "Confirmed" => "badge bg-info",
                                    "Completed" => "badge bg-success",
                                    "Cancelled" => "badge bg-danger",
                                    _ => "badge bg-secondary"
                                };

                                <tr>
                                    <td>
                                        <strong>#@order.OrderNumber</strong>
                                    </td>
                                    <td>
                                        <div>@(order.Customer?.FirstName ?? "-")</div>
                                        <small class="text-muted">@(order.Customer?.Email ?? "-")</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark">@sellerItemCount</span>
                                    </td>
                                    <td>
                                        <h6 class="mb-0">฿@order.TotalAmount.ToString("N2")</h6>
                                    </td>
                                    <td>
                                        <span class="text-success">฿@order.PaidAmount.ToString("N2")</span>
                                    </td>
                                    <td>
                                        <span class="@statusBadge">@order.Status</span>
                                    </td>
                                    <td>
                                        <small class="text-muted">@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                                    </td>
                                    <td>
                                        <a href="/Seller/Orders/@order.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                    <p class="mt-2">ยังไม่มีคำสั่งซื้อ</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
.table-hover tbody tr:hover { background: #f8f9fa; }
</style>
